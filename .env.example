# API Configuration & Server Port
PORT=8000

# PostgreSQL Connection String
# Used by orchestrator-api to connect to PostgreSQL.
# Note: In docker-compose, this uses the host "postgres-db"
DATABASE_URL=postgresql://admin:password@localhost:5432/research_db

# DuckDB Database Directory
# Directory where DuckDB workspace databases and .parquet files will be written
DUCKDB_DATA_DIR=./workspaces

# LLM Providers API Keys
GROQ_API_KEY=your_groq_api_key_here

# Data Provider API Keys & Settings
# Alpha Vantage configuration
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
AWS_PROFILE=default
DOMAIN_NAME=mcp.alphavantage.co
CERTIFICATE_ARN=arn:aws:acm:us-east-1:placeholder:certificate/placeholder

# World Bank Data360 configuration
DATA360_API_BASE_URL=https://data360api.worldbank.org
MCP_PORT=8022
MCP_TRANSPORT=sse

# LangSmith Tracing & Observability (Optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="Business Research Agent"
